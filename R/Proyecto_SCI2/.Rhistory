df <- read.csv("BD_Reactor.csv")
df <- df[,-1]
head(df)
str(df)
skim_without_charts(df)
#par(mfrow=c(2,2))
hist(df$DQO,
freq = FALSE,
main="Demanda Química de Oxígeno",
xlab="DQO",
ylab="Densidad")
lines(density(df$DQO, adjust = 3), col="red", lty=3)
boxplot(df$DQO,
main="Demanda Química de Oxígeno (DQO)",
xlab="DQO",
ylab="Concentraciones")
qqPlot(df$SSLM,
main="QQ-Normal de DQO",
xlab="Cuantiles muestrales",
ylab="Cuantiles teóricos normales")
