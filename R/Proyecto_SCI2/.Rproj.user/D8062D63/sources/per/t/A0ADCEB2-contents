## Caso de regresion polinomial

```{r}

df_auto <- mtcars
plot(df_auto$disp, df_auto$mpg)
scatter.smooth(df_auto$disp, df_auto$mpg)

modelo_lineal <- lm(data = df_auto, mpg ~ disp)
summary(modelo_lineal)

modelo_cuad <- lm(data = df_auto, mpg ~ disp + I(disp^2))
summary(modelo_cuad)

modelo_cub <- lm(data = df_auto, mpg ~ disp + I(disp^2) + I(disp^3))
summary(modelo_cub)


plot(df_auto$disp, df_auto$mpg)
abline(modelo_lineal, col="red")

plot(df_auto$disp, df_auto$mpg)
lines(sort(df_auto$disp),fitted(modelo_cuad)[order(df_auto$disp)], col="red", type = "l")

plot(df_auto$disp, df_auto$mpg)
lines(sort(df_auto$disp),fitted(modelo_cub)[order(df_auto$disp)], col="red", type = "l")

```